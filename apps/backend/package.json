{
  "name": "@layered/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --watch --import tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:setup": "node --env-file=.env.local --import tsx src/db/migrate.ts",
    "db:seed": "node --env-file=.env.local --import tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@layered/contracts": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.7",
    "postgres": "^3.4.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "drizzle-kit": "^0.31.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
